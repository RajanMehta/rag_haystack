# Copy to `.env` and fill in values. `.env` is gitignored;
# Only the vars actually exercised by your chosen PIPELINE_CONFIG need real values —
# unused ones can stay blank.

# ---- Qdrant (vector store) -------------------------------------------------
QDRANT_HOST=qdrant-server
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ---- Redis (Celery broker/backend) ----------------------------------------
REDIS_HOST=redis-server
REDIS_PORT=6379
REDIS_DB=0
REDIS_USER=
REDIS_PASSWORD=

# ---- Ollama (local LLM) ----------------------------------------------------
# Set OLLAMA_HOST for the local ollama-server container; set OLLAMA_EXT_LINK to
# reach an external endpoint. Using the wrong one causes request-time errors.
OLLAMA_HOST=
OLLAMA_EXT_LINK=
OLLAMA_API_KEY=
OLLAMA_MODEL=

# ---- OpenAI ----------------------------------------------------------------
# Optional at boot. If unset, /generate with model_type=openai returns 400 unless
# the request supplies `api_key` in its params.
OPENAI_API_KEY=

# ---- HuggingFace (build-time only) -----------------------------------------
# Needed only if you hit rate limits or pull gated models during `make build`.
HF_TOKEN=

# ---- Model cache override (optional) ---------------------------------------
# If set, the service looks here for `sentence-transformers/all-mpnet-base-v2/`
# before falling back to the baked-in /opt/hf_cache.
LOCAL_MODEL_DIR=

# ---- Pipeline selection ----------------------------------------------------
# Valid values: `en_gen`, `test`, or any key registered in
# experiments/_registry.py (e.g. `exp_001_smart_document_splitter`).
PIPELINE_CONFIG=en_gen

# ---- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
